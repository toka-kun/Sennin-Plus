{
  "$schema": "https://codesandbox.io/schemas/tasks.json",
  "setupTasks": [
    {
      "name": "Install dependencies",
      "command": "pip install -r requirements.txt"
    }
  ],
  "tasks": {
    "start": {
      "name": "Start Server",
      "command": "python main.py",
      "runAtStart": true,
      "preview": {
        "port": 8000,
        "scheme": "http"
      }
    }
  }
}
